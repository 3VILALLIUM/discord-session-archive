#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

remote_name="${1:-}"
zero_sha="0000000000000000000000000000000000000000"
outgoing_commits=()
if [[ "$remote_name" == "origin" ]]; then
  while read -r local_ref local_sha remote_ref remote_sha; do
    [[ -z "$local_ref" ]] && continue
    if [[ "$remote_ref" == "refs/heads/main" ]]; then
      echo "ERROR: direct pushes to origin/main are blocked. Open a PR." >&2
      exit 1
    fi
    if [[ "$local_sha" == "$zero_sha" ]]; then
      continue
    fi
    if [[ "$remote_sha" == "$zero_sha" ]]; then
      while read -r sha; do
        [[ -n "$sha" ]] && outgoing_commits+=("$sha")
      done < <(git rev-list "$local_sha" --not --remotes="$remote_name")
    else
      while read -r sha; do
        [[ -n "$sha" ]] && outgoing_commits+=("$sha")
      done < <(git rev-list "${remote_sha}..${local_sha}")
    fi
  done
else
  while read -r local_ref local_sha remote_ref remote_sha; do
    [[ -z "$local_ref" ]] && continue
    if [[ "$local_sha" == "$zero_sha" ]]; then
      continue
    fi
    if [[ "$remote_sha" == "$zero_sha" ]]; then
      while read -r sha; do
        [[ -n "$sha" ]] && outgoing_commits+=("$sha")
      done < <(git rev-list "$local_sha" --not --all)
    else
      while read -r sha; do
        [[ -n "$sha" ]] && outgoing_commits+=("$sha")
      done < <(git rev-list "${remote_sha}..${local_sha}")
    fi
  done
fi

if [[ ${#outgoing_commits[@]} -gt 0 ]]; then
  mapfile -t unique_commits < <(printf '%s\n' "${outgoing_commits[@]}" | sort -u)
  bash scripts/git_identity_guard.sh commits "${unique_commits[@]}"
fi

bash scripts/privacy_guard_check.sh
if [[ -f ".venv/Scripts/python.exe" ]]; then
  py=".venv/Scripts/python.exe"
elif [[ -f ".venv/bin/python" ]]; then
  py=".venv/bin/python"
else
  py="python"
fi

"$py" -m pytest -q
