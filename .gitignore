# LoreBot Git Ignore List
# =======================

# 1. Audio & Temp Artifacts
**/raw_audio/            # source .aac / .m4a
**/chunks/               # intermediate .flac chunks
**/merged/               # scratch JSON merges
**/dotmm_transcripts/    # Whisper chunk + combined JSON
*.aac
*.flac
*.mp3
*.zip                    # large archives (now in LFS)
*.dat                    # raw.dat blobs (now in LFS)
*.json                   # transcript JSON
*.log                    # run-time logs

# 2. Notebooks
*.ipynb
.ipynb_checkpoints/

# 3. Python Cache
__pycache__/
*.py[cod]

# 4. OS Trash
.DS_Store
Thumbs.db

# 5. Credentials / Secrets
.env
*.key
*.pem
*.csv

# 6. Editor Config (optional)
.vscode/

# 7. AI Staging Scratch
notebooklm_ready/