campaigns/**/dotmm_transcripts/**
campaigns/**/dotmm_session_output_overviews/**
campaigns/**/dotmm_sessions/**
campaigns/**/session_*/
campaigns/**/*_session_*/
campaigns/**/logs/**
campaigns/**/chunks/**
campaigns/**/raw_audio/**
campaigns/**/merged/**

# 2. Artifact file types
*.aac
*.flac
*.mp3
*.wav
*.m4a
*.mp4
*.json
*.log
*.txt
*.zip
*.dat

# 3. DOTMM strict allowlist
# Ignore everything in this campaign except scripts.
campaigns/dungeon_of_the_mad_mage/**
!campaigns/dungeon_of_the_mad_mage/dotmm_scripts/
!campaigns/dungeon_of_the_mad_mage/dotmm_scripts/**

# 4. Notebooks
*.ipynb
.ipynb_checkpoints/

# 5. Python cache
__pycache__/
*.py[cod]

# 6. OS trash
.DS_Store
Thumbs.db

# 7. Credentials / secrets
.env
*.key
*.pem
*.csv

# 8. Editor config
.vscode/

