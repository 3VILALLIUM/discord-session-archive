{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://discord-session-archive/schemas/transcribe_job.schema.json",
  "title": "Transcribe Job",
  "type": "object",
  "required": [
    "job_id", "job_type", "requested_at_utc", "session", "profile", "policy", "identity_mapping"
  ],
  "properties": {
    "job_id": { "type": "string", "minLength": 1 },
    "job_type": { "const": "transcribe_session" },
    "requested_at_utc": { "type": "string", "format": "date-time" },
    "session": {
      "type": "object",
      "required": ["session_uid", "source_type", "info_txt_uri", "audio_uri", "audio_layout", "audio_sha256"],
      "properties": {
        "session_uid": { "type": "string", "minLength": 1 },
        "source_type": { "const": "craig" },
        "info_txt_uri": { "type": "string", "pattern": "^(s3|gs|https?)://" },
        "audio_uri": { "type": "string", "pattern": "^(s3|gs|https?)://" },
        "audio_layout": { "const": "single_track_mixed" },
        "audio_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "profile": {
      "type": "object",
      "required": ["profile_id", "diarization_override"],
      "properties": {
        "profile_id": { "type": "string", "minLength": 1 },
        "diarization_override": { "type": ["boolean", "null"] }
      },
      "additionalProperties": false
    },
    "identity_mapping": {
      "type": "object",
      "required": ["required", "mapping_uri", "chosen_name_policy"],
      "properties": {
        "required": { "const": true },
        "mapping_uri": { "type": "string", "pattern": "^(s3|gs|https?)://" },
        "chosen_name_policy": { "enum": ["must_exist_or_fallback"] }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": ["require_mip_opt_out", "require_privacy_contract", "reject_if_policy_violation"],
      "properties": {
        "require_mip_opt_out": { "const": true },
        "require_privacy_contract": { "const": "1.0.0" },
        "reject_if_policy_violation": { "const": true }
      },
      "additionalProperties": false
    },
    "retry": {
      "type": "object",
      "properties": {
        "attempt": { "type": "integer", "minimum": 1 },
        "max_attempts": { "type": "integer", "minimum": 1, "maximum": 20 }
      },
      "additionalProperties": false
    },
    "trace": {
      "type": "object",
      "properties": {
        "correlation_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
